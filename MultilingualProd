#=============================Logging Setup========================================================
# Use a module-scoped logger (never mutate the root logger as an import side-effect, which would
# also change verbosity for the Azure SDKs / httpx and bypass host-side log configuration).
logger = logging.getLogger("multilingual_agent")
logger.setLevel(getattr(logging, os.getenv("LOG_LEVEL", "INFO").upper(), logging.INFO))

# The active request's correlation id, propagated to every log record via a filter so a single
# request can be traced end-to-end in Application Insights even under concurrent execution.
_correlation_id_var: "contextvars.ContextVar[str]" = contextvars.ContextVar(
    "correlation_id", default="-"
)


class _CorrelationIdFilter(logging.Filter):
    """Inject the current correlation id onto every record so it surfaces in App Insights."""

    def filter(self, record: logging.LogRecord) -> bool:  # noqa: A003
        if not hasattr(record, "correlation_id"):
            record.correlation_id = _correlation_id_var.get()
        return True


logger.addFilter(_CorrelationIdFilter())


#=============================Tunables (env-overridable)===========================================
def _int_env(name: str, default: int) -> int:
    """Read an int App Setting, falling back to `default` on missing/invalid values."""
    try:
        return int(os.getenv(name, str(default)))
    except (TypeError, ValueError):
        return default


def _float_env(name: str, default: float) -> float:
    """Read a float App Setting, falling back to `default` on missing/invalid values."""
    try:
        return float(os.getenv(name, str(default)))
    except (TypeError, ValueError):
        return default


# Reject messages longer than this (characters) with a 400 — bounds LLM token cost / abuse.
MAX_MESSAGE_CHARS = _int_env("MAX_MESSAGE_CHARS", 5000)
# Per-request timeout (seconds) applied to the Foundry/OpenAI client. Generous enough for a
# slow-but-legitimate translation, but well under the Azure Functions ~230s HTTP hard limit
# and the host.json functionTimeout so a hung upstream call cannot pin a worker indefinitely.
FOUNDRY_TIMEOUT_SECONDS = _float_env("FOUNDRY_TIMEOUT_SECONDS", 60.0)
# Automatic retries (SDK-level) on transient Foundry failures (429 / 5xx / timeouts). Kept low
# so worst-case (attempts x timeout) stays inside functionTimeout.
FOUNDRY_MAX_RETRIES = _int_env("FOUNDRY_MAX_RETRIES", 1)


