#=========================================Helpers: Loading Configuration===========================
_DEFAULT_ENDPOINT = (
    "https://aifoundry-rjteh-ais-swce-poc.services.ai.azure.com/api/projects/aifp-uqqnf-ais-swce-poc"
)


def load_config() -> AppConfig:
    """
    Build the AppConfig from environment variables (App Settings) with safe defaults.

    Every value is overridable WITHOUT a code redeploy via
    Function App -> Configuration -> Application settings:

        FOUNDRY_ENDPOINT   - the Foundry PROJECT endpoint.
        FOUNDRY_AGENT_NAME - agent display name (default 'multilingual-agent').
        ENVIRONMENT        - free-text label for the response (default 'dev').

    Returns:
        AppConfig: Fully-populated configuration object.
    """
    endpoint = os.getenv("FOUNDRY_ENDPOINT", _DEFAULT_ENDPOINT)
    if endpoint == _DEFAULT_ENDPOINT and not os.getenv("FOUNDRY_ENDPOINT"):
        # Not fatal (keeps the POC working out of the box) but flagged so prod can't rely on it.
        logger.warning("FOUNDRY_ENDPOINT not set; using the built-in default endpoint.")
    foundry_cfg = FoundryConfig(
        endpoint=endpoint,
        agent_name=os.getenv("FOUNDRY_AGENT_NAME", "multilingual-agent"),
    )
    return AppConfig(environment=os.getenv("ENVIRONMENT", "dev"), foundry=foundry_cfg)


#==============================================Utilities===========================================
def json_response(payload: Dict[str, Any], status: int = 200) -> func.HttpResponse:
    """
    Build a JSON HTTP response.

    ensure_ascii=False keeps non-Latin scripts (Hebrew, Japanese, Chinese, ...)
    readable in the body instead of being escaped to \\uXXXX.
    """
    return func.HttpResponse(
        body=json.dumps(payload, ensure_ascii=False),
        status_code=status,
        mimetype="application/json",
    )


def error_response(
    message: str, details: str, status: int, correlation_id: str
) -> func.HttpResponse:
    """Standard error envelope. Always carries the correlation_id so callers can quote it."""
    return json_response(
        {
            "Success": False,
            "error": {"message": message, "details": details},
            "correlation_id": correlation_id,
        },
        status=status,
    )


def get_default_credential():
    """
    Create the credential used to authenticate against the Foundry endpoint.

    The Foundry 'projects' endpoint accepts Microsoft Entra ID (AAD) tokens only.

    Deployed (Azure): resolves to the Function App's Managed Identity through
        DefaultAzureCredential. The identity must sit in the SAME tenant as the
        Foundry project and hold the 'Azure AI User' role on that project.

    Local testing: set LOCAL_INTERACTIVE_LOGIN=1 to sign in through the browser
        instead (handy when the Azure CLI is unavailable). Set AZURE_TENANT_ID to
        target a specific directory. This branch is never taken in Azure because
        the environment variable is not set there.

    Returns:
        A credential object suitable for the Foundry client.
    """
    tenant_id = os.getenv("AZURE_TENANT_ID") or None

    # Local, developer-only interactive sign-in path.
    if os.getenv("LOCAL_INTERACTIVE_LOGIN", "").lower() in ("1", "true", "yes"):
        from azure.identity import InteractiveBrowserCredential

        logger.info("Using InteractiveBrowserCredential for local sign-in (tenant=%s).",
                    tenant_id or "default")
        return InteractiveBrowserCredential(tenant_id=tenant_id)

    # Deployed path: Managed Identity. Interactive/dev credential sources are
    # excluded so credential resolution is fast and deterministic in Azure.
    return DefaultAzureCredential(
        exclude_interactive_browser_credential=True,
        exclude_visual_studio_code_credential=True,
        exclude_shared_token_cache_credential=True,
        exclude_powershell_credential=True,
    )


_CORRELATION_ID_RE = re.compile(r"[A-Za-z0-9._-]{1,64}\Z")


def sanitize_correlation_id(raw: Optional[str]) -> str:
    """
    Return a safe correlation id.

    A caller-supplied x-correlation-id is honoured ONLY if it is short and free of control
    characters (letters/digits/._- , <=64 chars); otherwise a fresh UUID is generated. This
    prevents log-injection / forged-trace attacks via a hostile header.
    """
    if raw and _CORRELATION_ID_RE.match(raw):
        return raw
    return str(uuid.uuid4())


def get_json_body(req: func.HttpRequest) -> Dict[str, Any]:
    """Parse the JSON body once; return {} when missing or invalid so callers can .get()."""
    try:
        body = req.get_json()
    except ValueError:
        return {}
    return body if isinstance(body, dict) else {}


def extract_agent(req: func.HttpRequest, body: Dict[str, Any]) -> Optional[str]:
    """Read the mode ('detect' / 'translate') from the query string or body, lower-cased."""
    agent = req.params.get("agent") or body.get("agent")
    if isinstance(agent, str) and agent.strip():
        return agent.strip().lower()
    return None


def extract_message(req: func.HttpRequest, body: Dict[str, Any]) -> Optional[str]:
    """Read the user message from the query string or JSON body (several keys accepted)."""
    message = req.params.get("message") or req.params.get("q") or req.params.get("query")
    if message:
        return message
    return (
        body.get("message")
        or body.get("query")
        or body.get("text")
        or body.get("prompt")
    )


def extract_lang(req: func.HttpRequest, body: Dict[str, Any]) -> Optional[str]:
    """Read the raw target language token for 'translate' (query string or body)."""
    lang = (
        req.params.get("lang")
        or req.params.get("language")
        or body.get("lang")
        or body.get("language")
    )
    if isinstance(lang, str) and lang.strip():
        return lang.strip()
    return None


