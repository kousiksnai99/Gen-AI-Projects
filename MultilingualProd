# ISO 639-1 code -> display name, for the SUPPORTED languages only. This is the
# single source of truth for what the service will detect/accept as supported.
SUPPORTED: Dict[str, str] = {
    "en": "English",
    "he": "Hebrew",
    "hr": "Croatian",
    "bg": "Bulgarian",
    "ro": "Romanian",
    "fr": "French",
    "de": "German",
    "cs": "Czech",
    "ru": "Russian",
    "it": "Italian",
    "nl": "Dutch",
    "hu": "Hungarian",
    "pl": "Polish",
    "es": "Spanish",
    "sl": "Slovenian",
    "sk": "Slovak",
    "el": "Greek",
    "pt": "Portuguese",
    "sr": "Serbian",
    "bs": "Bosnian",
    "mk": "Macedonian",
    "kk": "Kazakh",
    "uk": "Ukrainian",
    "ko": "Korean",
    "ja": "Japanese",
    "ms": "Malay",
    "id": "Indonesian",
    "th": "Thai",
